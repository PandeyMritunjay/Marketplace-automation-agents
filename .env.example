# Database Configuration
# For MySQL (SSMS): mysql+pymysql://user:password@localhost:3306/database_name
# For PostgreSQL: postgresql://user:password@localhost:5432/database_name
MARKETPLACE_DB_URL=mysql+pymysql://root:password@localhost:3306/marketplace
AGENT_DB_URL=mysql+pymysql://root:password@localhost:3306/agent_system

# OpenAI API
OPENAI_API_KEY=

# Slack Configuration
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_DISPUTES=#disputes
SLACK_CHANNEL_SUPPORT=#support-queue
SLACK_CHANNEL_OPS=#ops-daily

# Gmail API Configuration
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json
GMAIL_SUPPORT_EMAIL=support@marketplace.com

# Agent Configuration
DISPUTE_AUTO_REFUND_THRESHOLD=200
DISPUTE_HIGH_CONFIDENCE_THRESHOLD=0.85
DISPUTE_MEDIUM_CONFIDENCE_THRESHOLD=0.70

SUPPORT_BATCH_APPROVE_ENABLED=true
SUPPORT_KEYWORD_OVERRIDE=lawyer,chargeback,leaving the platform,fraud,missing payment,payout,legal

OPERATOR_PAYOUT_PENDING_DAYS=7
OPERATOR_UNFULFILLED_DAYS=5
OPERATOR_INACTIVE_DAYS=14

# Logging
LOG_LEVEL=INFO
